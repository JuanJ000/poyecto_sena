# ════════════════════════════════════════════════════════════════════
# TIENDA X - Variables de Entorno
# Copia este archivo a .env y completa con tus valores
# ════════════════════════════════════════════════════════════════════

# ENTORNO
# Valores: development, production, test
NODE_ENV=development

# PUERTO
PORT=3000

# ════════════════════════════════════════════════════════════════════
# BASE DE DATOS - MongoDB
# ════════════════════════════════════════════════════════════════════
# Formato local: mongodb://localhost:27017/tiendax
# Formato remoto: mongodb+srv://usuario:password@cluster.mongodb.net/tiendax
MONGO_URI=mongodb://localhost:27017/tiendax

# ════════════════════════════════════════════════════════════════════
# JWT - Autenticación
# ════════════════════════════════════════════════════════════════════
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secret_key_muy_segura_y_aleatoria_aqui_cambiar

# ════════════════════════════════════════════════════════════════════
# ADMIN
# ════════════════════════════════════════════════════════════════════
# Contraseña para acceso admin
ADMIN_PASSWORD=tu_contraseña_admin_segura_aqui

# ════════════════════════════════════════════════════════════════════
# EMAIL - Gmail SMTP
# ════════════════════════════════════════════════════════════════════
# Usuario Gmail (correo completo)
GMAIL_USER=tu_email@gmail.com

# Contraseña de aplicación Gmail (NO la contraseña normal)
# Generar en: https://myaccount.google.com/apppasswords
GMAIL_PASS=tu_app_password_aqui

# Email del administrador para notificaciones
EMAIL_ADMIN=admin@tutienda.com

# ════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ════════════════════════════════════════════════════════════════════
# 1. NUNCA commits este archivo con valores reales a Git
# 2. Añade .env a .gitignore
# 3. Para Gmail: usa contraseña de aplicación, no tu contraseña normal
# 4. JWT_SECRET debe ser largo, aleatorio y seguro
# 5. En producción, usa variables de entorno del servidor (no archivo .env)
